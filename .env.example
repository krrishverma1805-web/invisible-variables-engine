# =============================================================================
# Invisible Variables Engine - Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
ENV=development                          # development | staging | production
SECRET_KEY=change-me-to-a-secure-random-string-of-at-least-32-chars
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR
API_PORT=8000
DEBUG=true

# ---------------------------------------------------------------------------
# API Authentication
# ---------------------------------------------------------------------------
API_KEY_HEADER=X-API-Key
# Comma-separated list of valid API keys (rotate periodically)
VALID_API_KEYS=dev-key-1,dev-key-2

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ive
POSTGRES_PASSWORD=ivepassword
POSTGRES_DB=ive_db
# Assembled by the app from the above; override directly if needed
DATABASE_URL=postgresql+asyncpg://ive:ivepassword@localhost:5432/ive_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# ---------------------------------------------------------------------------
# Redis (Celery Broker + Cache)
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword
REDIS_DB=0
REDIS_URL=redis://:redispassword@localhost:6379/0

# ---------------------------------------------------------------------------
# Celery Worker
# ---------------------------------------------------------------------------
CELERY_CONCURRENCY=4
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_EXPIRES=86400             # 24 hours in seconds
CELERY_MAX_TASKS_PER_CHILD=100

# ---------------------------------------------------------------------------
# Celery Flower Monitoring
# ---------------------------------------------------------------------------
FLOWER_PORT=5555
FLOWER_USER=admin
FLOWER_PASSWORD=flowerpass

# ---------------------------------------------------------------------------
# Streamlit UI
# ---------------------------------------------------------------------------
STREAMLIT_PORT=8501
API_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Storage (Artifacts / Model Files)
# ---------------------------------------------------------------------------
ARTIFACT_STORE_TYPE=local               # local | s3
ARTIFACT_BASE_DIR=/app/artifacts

# S3 settings (only if ARTIFACT_STORE_TYPE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=ive-artifacts

# ---------------------------------------------------------------------------
# ML Configuration
# ---------------------------------------------------------------------------
DEFAULT_CV_FOLDS=5
DEFAULT_TEST_SIZE=0.2
RANDOM_SEED=42
MAX_FEATURES=100
MIN_CLUSTER_SIZE=10                     # HDBSCAN minimum cluster size
SHAP_SAMPLE_SIZE=500                    # Max samples for SHAP computation

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60                    # seconds

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
SENTRY_DSN=                             # Leave empty to disable
ENABLE_METRICS=false
PROMETHEUS_PORT=9090

# ---------------------------------------------------------------------------
# LLM Enrichment (Groq / OpenAI-compatible)
# ---------------------------------------------------------------------------
# Off by default. Flip LLM_EXPLANATIONS_ENABLED=true to post-process pipeline
# output via Groq. Every output is validated against input facts; any failure
# falls back cleanly to the rule-based prose generator.
#
# Self-hosted: set LLM_SELF_HOSTED_MODE=true and point GROQ_BASE_URL at a
# vLLM or other OpenAI-compatible server. See docs/self_hosted_llm.md.

LLM_EXPLANATIONS_ENABLED=false
LLM_SELF_HOSTED_MODE=false

GROQ_API_KEY=                            # Required when enabled in production
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=15.0
GROQ_MAX_RETRIES=3
GROQ_MAX_OUTPUT_TOKENS=512
GROQ_TEMPERATURE=0.0                     # 0.0 = deterministic prose
GROQ_MAX_CONCURRENCY=2                   # Free-tier safe; raise after measuring

# Caching / breaker / budget
LLM_CACHE_TTL_SECONDS=604800             # 7 days
LLM_REDIS_DB=2                           # 0=broker, 1=results, 2=LLM cache
LLM_PROMPT_VERSION=v1                    # Embedded in cache key
LLM_CIRCUIT_BREAKER_THRESHOLD=5
LLM_CIRCUIT_BREAKER_COOLDOWN_SECONDS=300
LLM_VALIDATION_RETRY_MAX=1               # Sharpened re-prompts before fallback
LLM_BATCH_SIZE_LVS=8                     # LVs per batched call
LLM_BATCH_TOKEN_SAFETY_THRESHOLD=8000
LLM_DAILY_TOKEN_BUDGET=1000000           # Total billable tokens/day
LLM_PER_EXPERIMENT_TOKEN_CAP=200000
LLM_DATA_EGRESS_DEFAULT=deny             # Conservative per-column policy default
LLM_VALIDATOR_PROFILE=groq_llama_3_3_70b
